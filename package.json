{
  "name": "@xiaok/openclaw-lark-extended",
  "version": "0.2.0",
  "description": "XiaoK-maintained fork of @larksuite/openclaw-lark, tracking upstream and carrying Feishu/Lark group-context, sender-name enrichment, message-read, and social extensions.",
  "license": "MIT",
  "author": "Lucien",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KevinWangQQ/openclaw-lark-xiaok.git"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openclaw-lark": "bin/openclaw-lark.js"
  },
  "files": [
    "**/*"
  ],
  "keywords": [
    "openclaw",
    "feishu",
    "lark",
    "channel",
    "plugin",
    "fork"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@sinclair/typebox": "0.34.48",
    "image-size": "^2.0.2",
    "undici-types": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "channel": {
      "id": "openclaw-lark",
      "label": "Feishu",
      "selectionLabel": "Lark/Feishu (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "Feishu/Lark enterprise messaging with doc/wiki/drive/task/calendar tools (extended fork).",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@lucien/openclaw-lark-extended",
      "localPath": "extensions/feishu",
      "defaultChoice": "npm"
    }
  },
  "bugs": {
    "url": "https://github.com/KevinWangQQ/openclaw-lark-xiaok/issues"
  },
  "homepage": "https://github.com/KevinWangQQ/openclaw-lark-xiaok#readme"
}
